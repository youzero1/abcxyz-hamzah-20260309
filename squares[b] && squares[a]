squares[c]) {
      return {
        winner: squares[a] as Player,
        isDraw: false,
        winningLine: line,
      };
    }
  }

  const isDraw = squares.every((cell) => cell !== null);
  return {
    winner: null,
    isDraw,
    winningLine: null,
  };
}

export function isBoardFull(squares: BoardState): boolean {
  return squares.every((cell) => cell !== null);
}

export function isValidMove(squares: BoardState, index: number): boolean {
  return index >= 0 && index < 9 && squares[index] === null;
}
