'use client';

import { useState } from 'react';

interface ShareButtonProps {
  playerX: string;
  playerO: string;
  winner: string | null;
  moveCount: number;
}

export default function ShareButton({ playerX, playerO, winner, moveCount }: ShareButtonProps) {
  const [copied, setCopied] = useState(false);

  const handleShare = async () => {
    let resultText: string;
    if (winner === 'X') {
      resultText = `${playerX} (X) beat ${playerO} (O)`;
    } else if (winner === 'O') {
      resultText = `${playerO} (O) beat ${playerX} (X)`;
    } else {
      resultText = `${playerX} (X) and ${playerO} (O) drew`;
    }

    const shareText = `🎮 abcxyz Tic Tac Toe\n${resultText} in ${moveCount} moves!\n\nPlay at: ${window.location.origin}`;

    try {
      if (navigator.share) {
        await navigator.share({
          title: 'abcxyz - Tic Tac Toe Result',
          text: shareText,
        });
      } else {
        await navigator.clipboard.writeText(shareText);
        setCopied(true);
        setTimeout(() => setCopied(false), 2000);
      }
    } catch {
      // User cancelled share or clipboard failed
      try {
        await navigator.clipboard.writeText(shareText);
        setCopied(true);
        setTimeout(() => setCopied(false), 2000);
      } catch {
        // Clipboard also failed, silently ignore
      }
    }
  };

  return (
    <button onClick={handleShare} className="btn-secondary">
      {copied ? '✅ Copied!' : '📤 Share Result'}
    </button>
  );
}
